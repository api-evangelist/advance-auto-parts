{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ErrorResponse",
  "description": "API error response.",
  "type": "object",
  "properties": {
    "code": {
      "type": "string",
      "description": "Error code.",
      "example": "NOT_FOUND"
    },
    "message": {
      "type": "string",
      "description": "Error message.",
      "example": "The requested resource was not found."
    }
  }
}